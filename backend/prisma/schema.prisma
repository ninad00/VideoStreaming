// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum VideoStatus {
  UPLOADED
  PROCESSING
  TRANSCODED
  FAILED
}

enum SubtitleStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  username     String  @unique
  passwordHash String
  avatarUrl    String?
  googlesub    String? @unique
  
  // Relations
  videos       Video[] // One-to-many relationship with Video
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Video {
  id           String  @id @default(uuid())
  title        String?
  description  String?
  thumbnail    String?
  hls          String?
  
  // Relations
  userId       String
  uploader     User    @relation(fields: [userId], references: [id])

  // S3
  rawBucket    String
  outBucket    String

  // System Status & State Checkpointing
  status         VideoStatus    @default(UPLOADED)
  subtitleStatus SubtitleStatus @default(PENDING)

  // Optimistic Concurrency Control (Row-level locking)
  version      Int @default(1)

  // Optional metadata
  duration     Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Indexes for query performance optimization
  @@index([userId])
  @@index([status, subtitleStatus]) // Composite index for worker sweeper jobs
  @@index([createdAt(sort: Desc)])
}
